generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  subscriptions Subscription[]
  payments      Payment[]
  usage         ServiceUsage[]
}

model Plan {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  price     Int
  currency  String   @default("PKR")
  features  Json?
  limits    Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  subs      Subscription[]
  payments  Payment[]
}

model Subscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  plan      Plan     @relation(fields: [planId], references: [id])
  planId    String
  status    SubStatus @default(ACTIVE)
  startedAt DateTime  @default(now())
  expiresAt DateTime?
  cancelAt  DateTime?
  @@unique([userId, planId])
}

model Payment {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  plan       Plan     @relation(fields: [planId], references: [id])
  planId     String
  method     PaymentMethod
  amount     Int
  currency   String   @default("PKR")
  invoiceId  String   @unique
  receiptUrl String?
  status     PaymentStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime @default(now())
}

model ServiceUsage {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  metric      String
  count       Int      @default(0)
  periodStart DateTime
  periodEnd   DateTime
}

enum Role {
  USER
  ADMIN
}

enum PaymentMethod {
  PAYONEER
  BANK
}

enum PaymentStatus {
  PENDING
  APPROVED
  DECLINED
}

enum SubStatus {
  ACTIVE
  CANCELED
  EXPIRED
}
